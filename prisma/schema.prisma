generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUser {
  id                 Int       @id @default(autoincrement())
  username           String    @unique
  displayName        String
  role               String
  passwordHash       String
  passwordSalt       String
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime?
  lastLoginAt        DateTime?
  dingtalkUserId     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model FinanceOrder {
  id                        Int                     @id @default(autoincrement())
  importBatchId             Int?
  importBatch               ImportBatch?            @relation(fields: [importBatchId], references: [id])
  orderNo                   String
  customerOrderNo           String?
  orderDate                 DateTime
  month                     String
  customerName              String
  customerType              String
  salespersonName           String
  customerServiceName       String?
  businessType              String
  supplierName              String?
  currency                  String
  exchangeRate              Float?
  exchangeRateSource        String?
  exchangeRateStatus        String
  receivableFreight         Float                   @default(0)
  receivableClearance       Float                   @default(0)
  receivableDelivery        Float                   @default(0)
  receivableCompensation    Float                   @default(0)
  otherReceivable           Float                   @default(0)
  payableFreight            Float                   @default(0)
  payableClearance          Float                   @default(0)
  payableDelivery           Float                   @default(0)
  payableCompensation       Float                   @default(0)
  otherCost                 Float                   @default(0)
  adjustedReceivable        Float                   @default(0)
  adjustedPayable           Float                   @default(0)
  adjustedGrossProfit       Float                   @default(0)
  adjustedGrossProfitRate   Float?
  receivedAmount            Float                   @default(0)
  paidAmount                Float                   @default(0)
  orderStatus               String
  receivableStatus          String
  payableStatus             String
  isServiceBusiness         Boolean                 @default(false)
  isCompanyCustomerAdjusted Boolean                 @default(false)
  needSupervisorConfirm     Boolean                 @default(false)
  calculationNote           String?
  remark                    String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  chargeLines               FinanceChargeLine[]
  commissionRecords         CommissionRecord[]
  riskRecords               RiskRecord[]
  costAdjustments           CostAdjustment[]
  serviceBusinessRecords    ServiceBusinessRecord[]
  settlementRecords         SettlementRecord[]
  invoices                  FinanceInvoice[]

  @@unique([month, orderNo])
  @@index([orderNo])
}

model OperatorPerformanceOverride {
  id           Int      @id @default(autoincrement())
  month        String
  operatorName String
  category     String
  orderCount   Int?
  baseCount    Int?
  rate         Float?
  updatedBy    String   @default("主管")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([month, operatorName, category])
  @@index([month, operatorName])
}

model OperatorPerformanceMonthSetting {
  id         Int      @id @default(autoincrement())
  month      String   @unique
  payoutNote String
  updatedBy  String   @default("主管")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SettlementRecord {
  id                 Int                        @id @default(autoincrement())
  financeOrderId     Int
  financeOrder       FinanceOrder               @relation(fields: [financeOrderId], references: [id])
  month              String
  direction          String
  amount             Float
  settledAt          DateTime
  counterparty       String?
  status             String                     @default("active")
  operator           String                     @default("finance")
  note               String?
  voidedBy           String?
  voidedAt           DateTime?
  voidReason         String?
  createdAt          DateTime                   @default(now())
  invoiceAllocations FinanceInvoiceAllocation[]

  @@index([month, direction])
  @@index([financeOrderId, direction])
}

model RawLedgerLine {
  id              Int                 @id @default(autoincrement())
  importBatchId   Int
  importBatch     ImportBatch         @relation(fields: [importBatchId], references: [id])
  month           String
  orderNo         String?
  customerOrderNo String?
  rowIndex        Int
  sheetName       String
  sourceFileName  String
  rowHash         String
  rawJson         String
  canonicalJson   String?
  parseStatus     String              @default("parsed")
  parseMessage    String?
  createdAt       DateTime            @default(now())
  chargeLines     FinanceChargeLine[]

  @@unique([importBatchId, rowIndex])
  @@index([month, orderNo])
  @@index([importBatchId, rowIndex])
}

model BusinessPartner {
  id               Int                    @id @default(autoincrement())
  partnerCode      String                 @unique
  partnerType      String
  name             String
  taxNumber        String?
  contactName      String?
  contactPhone     String?
  currency         String                 @default("CNY")
  creditLimit      Float                  @default(0)
  paymentTermDays  Int                    @default(30)
  isActive         Boolean                @default(true)
  source           String                 @default("manual")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  invoices         FinanceInvoice[]
  bankTransactions BankTransaction[]
  aliases          BusinessPartnerAlias[]

  @@index([partnerType, isActive])
  @@index([name])
}

model BusinessPartnerAlias {
  id                Int             @id @default(autoincrement())
  businessPartnerId Int
  businessPartner   BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)
  partnerType       String
  alias             String
  normalizedAlias   String
  source            String          @default("manual")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([partnerType, normalizedAlias])
  @@index([businessPartnerId])
  @@index([alias])
}

model FinanceInvoice {
  id                    Int                        @id @default(autoincrement())
  invoiceNo             String                     @unique
  month                 String
  invoiceType           String
  partnerId             Int?
  partner               BusinessPartner?           @relation(fields: [partnerId], references: [id])
  financeOrderId        Int?
  financeOrder          FinanceOrder?              @relation(fields: [financeOrderId], references: [id])
  orderNo               String?
  currency              String                     @default("CNY")
  exchangeRate          Float                      @default(1)
  originalAmount        Float                      @default(0)
  localAmount           Float                      @default(0)
  allocatedAmount       Float                      @default(0)
  issuedAt              DateTime
  dueAt                 DateTime
  status                String                     @default("open")
  source                String                     @default("finance_order")
  note                  String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  allocations           FinanceInvoiceAllocation[]
  reconciliationMatches ReconciliationMatch[]

  @@unique([month, invoiceType, financeOrderId])
  @@index([month, invoiceType, status])
  @@index([partnerId, dueAt])
}

model FinanceInvoiceAllocation {
  id                 Int               @id @default(autoincrement())
  invoiceId          Int
  invoice            FinanceInvoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  settlementRecordId Int?
  settlementRecord   SettlementRecord? @relation(fields: [settlementRecordId], references: [id])
  bankTransactionId  Int?
  bankTransaction    BankTransaction?  @relation(fields: [bankTransactionId], references: [id])
  amount             Float
  status             String            @default("active")
  createdBy          String            @default("finance")
  createdAt          DateTime          @default(now())

  @@unique([invoiceId, settlementRecordId])
  @@index([invoiceId, status])
  @@index([settlementRecordId])
  @@index([bankTransactionId])
}

model BankTransaction {
  id                    Int                        @id @default(autoincrement())
  transactionNo         String                     @unique
  month                 String
  transactionDate       DateTime
  direction             String
  partnerId             Int?
  partner               BusinessPartner?           @relation(fields: [partnerId], references: [id])
  manualLedgerEntryId   Int?                       @unique
  manualLedgerEntry     ManualLedgerEntry?         @relation(fields: [manualLedgerEntryId], references: [id])
  counterparty          String
  bankReference         String?
  currency              String                     @default("CNY")
  exchangeRate          Float                      @default(1)
  originalAmount        Float
  localAmount           Float
  matchedAmount         Float                      @default(0)
  status                String                     @default("unmatched")
  source                String                     @default("manual")
  note                  String?
  createdBy             String                     @default("finance")
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  allocations           FinanceInvoiceAllocation[]
  reconciliationMatches ReconciliationMatch[]

  @@index([month, direction, status])
  @@index([transactionDate])
}

model ReconciliationMatch {
  id                Int             @id @default(autoincrement())
  bankTransactionId Int
  bankTransaction   BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  invoiceId         Int
  invoice           FinanceInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  suggestedAmount   Float
  score             Float
  matchReason       String
  status            String          @default("suggested")
  confirmedBy       String?
  confirmedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([bankTransactionId, invoiceId])
  @@index([status, score])
}

model WorkflowTask {
  id          Int       @id @default(autoincrement())
  sourceKey   String    @unique
  month       String
  taskType    String
  entityType  String
  entityId    String
  title       String
  description String?
  ownerRole   String
  ownerName   String?
  priority    String    @default("normal")
  status      String    @default("pending")
  route       String?
  dueAt       DateTime?
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([month, status, priority])
  @@index([ownerRole, ownerName, status])
}

model FinanceChargeLine {
  id                  Int            @id @default(autoincrement())
  importBatchId       Int
  importBatch         ImportBatch    @relation(fields: [importBatchId], references: [id])
  financeOrderId      Int?
  financeOrder        FinanceOrder?  @relation(fields: [financeOrderId], references: [id])
  rawLedgerLineId     Int?
  rawLedgerLine       RawLedgerLine? @relation(fields: [rawLedgerLineId], references: [id])
  month               String
  orderNo             String
  customerOrderNo     String?
  customerName        String?
  salespersonName     String?
  customerServiceName String?
  direction           String
  feeType             String
  service             String?
  supplierName        String?
  currency            String?
  exchangeRate        Float?
  originalAmount      Float          @default(0)
  localAmount         Float          @default(0)
  signedAmount        Float          @default(0)
  isCompensation      Boolean        @default(false)
  isServiceBusiness   Boolean        @default(false)
  rowIndex            Int
  sourceFileName      String?
  createdAt           DateTime       @default(now())

  @@index([month, orderNo])
  @@index([importBatchId, rowIndex])
  @@index([financeOrderId])
  @@index([rawLedgerLineId])
  @@index([month, direction, feeType])
}

model ImportBatch {
  id                      Int                 @id @default(autoincrement())
  batchNo                 String              @unique
  month                   String
  fileName                String
  sheetName               String
  importMode              String              @default("replace_month")
  status                  String              @default("active")
  importedRows            Int                 @default(0)
  importedOrders          Int                 @default(0)
  logisticsOrders         Int                 @default(0)
  serviceOrders           Int                 @default(0)
  totalReceivable         Float               @default(0)
  totalPayable            Float               @default(0)
  totalGrossProfit        Float               @default(0)
  riskOrderCount          Int                 @default(0)
  abnormalHighProfitCount Int                 @default(0)
  templateAuditJson       String?
  previewJson             String?
  sourceFileData          Bytes?
  sourceFileSha256        String?
  sourceFileSize          Int?
  createdBy               String              @default("system")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  revertedAt              DateTime?
  financeOrders           FinanceOrder[]
  rawLedgerLines          RawLedgerLine[]
  chargeLines             FinanceChargeLine[]

  @@index([month, status])
}

model FinanceSummary {
  id                            Int      @id @default(autoincrement())
  month                         String   @unique
  totalReceivable               Float    @default(0)
  totalPayable                  Float    @default(0)
  totalReceived                 Float    @default(0)
  totalPaid                     Float    @default(0)
  totalGrossProfit              Float    @default(0)
  grossProfitRate               Float?
  totalCommission               Float    @default(0)
  riskOrderCount                Int      @default(0)
  abnormalHighProfitOrderCount  Int      @default(0)
  pendingSupervisorConfirmCount Int      @default(0)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model MonthClose {
  id         Int       @id @default(autoincrement())
  month      String    @unique
  status     String    @default("open")
  lockedBy   String?
  lockedAt   DateTime?
  unlockedBy String?
  unlockedAt DateTime?
  closeNote  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ExcelImportTemplate {
  id             Int      @id @default(autoincrement())
  templateKey    String   @unique
  fileName       String
  sheetName      String
  headerRowIndex Int      @default(1)
  headersJson    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ParameterRule {
  id          Int                    @id @default(autoincrement())
  ruleKey     String                 @unique
  ruleGroup   String
  label       String
  valueJson   String
  description String?
  isActive    Boolean                @default(true)
  updatedBy   String                 @default("system")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    ParameterRuleVersion[]

  @@index([ruleGroup, isActive])
}

model ParameterRuleVersion {
  id              Int           @id @default(autoincrement())
  parameterRuleId Int
  parameterRule   ParameterRule @relation(fields: [parameterRuleId], references: [id], onDelete: Cascade)
  effectiveMonth  String
  valueJson       String
  description     String?
  isActive        Boolean       @default(true)
  updatedBy       String        @default("system")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([parameterRuleId, effectiveMonth])
  @@index([effectiveMonth, isActive])
}

model CommissionRecord {
  id                     Int          @id @default(autoincrement())
  financeOrderId         Int
  financeOrder           FinanceOrder @relation(fields: [financeOrderId], references: [id])
  salespersonName        String
  customerType           String
  businessType           String
  grossProfit            Float
  commissionRate         Float
  commissionAmount       Float
  manualCommissionAmount Float?
  adjustReason           String?
  needSupervisorConfirm  Boolean      @default(false)
  confirmStatus          String       @default("pending")
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model RiskRecord {
  id               Int          @id @default(autoincrement())
  financeOrderId   Int
  financeOrder     FinanceOrder @relation(fields: [financeOrderId], references: [id])
  riskLevel        String
  riskType         String
  riskReasons      String
  suggestion       String
  status           String       @default("open")
  reviewNote       String?
  reviewConclusion String?
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model CostAdjustment {
  id                    Int          @id @default(autoincrement())
  financeOrderId        Int
  financeOrder          FinanceOrder @relation(fields: [financeOrderId], references: [id])
  fieldName             String
  oldValue              Float?
  newValue              Float?
  adjustmentLogic       String
  reason                String
  operatorName          String
  needSupervisorConfirm Boolean      @default(false)
  createdAt             DateTime     @default(now())
}

model ServiceBusinessRecord {
  id                        Int          @id @default(autoincrement())
  financeOrderId            Int
  financeOrder              FinanceOrder @relation(fields: [financeOrderId], references: [id])
  serviceType               String
  originalPrice             Float
  suggestedPrice            Float?
  suggestedCommissionMin    Float?
  suggestedCommissionMax    Float?
  costAmount                Float?
  grossProfit               Float?
  supervisorFinalPrice      Float?
  supervisorFinalCommission Float?
  confirmStatus             String       @default("pending")
  remark                    String?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
}

model ConfirmationDocument {
  id                      Int       @id @default(autoincrement())
  month                   String
  documentType            String
  ownerName               String
  version                 Int       @default(1)
  businessType            String?
  orderCount              Int       @default(0)
  grossProfit             Float     @default(0)
  commissionAmount        Float     @default(0)
  payloadJson             String?
  documentStatus          String    @default("generated")
  sendStatus              String    @default("unsent")
  notificationChannel     String?
  notifiedAt              DateTime?
  notificationReceiptJson String?
  notificationError       String?
  signatureStatus         String    @default("pending")
  supervisorStatus        String    @default("pending")
  signatureToken          String?   @unique
  signatureUrl            String?
  signatureTokenExpiresAt DateTime?
  signerIp                String?
  signerUserAgent         String?
  signerRole              String?
  signatureEvidenceJson   String?
  adjustReason            String?
  voidReason              String?
  signedAt                DateTime?
  confirmedAt             DateTime?
  voidedAt                DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([month, documentType, ownerName, version])
  @@index([month, documentType])
  @@index([month, documentType, ownerName])
}

model ExportJob {
  id          Int      @id @default(autoincrement())
  month       String
  exportType  String
  fileFormat  String
  status      String   @default("ready")
  fileName    String
  payloadJson String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([month, exportType])
}

model ManualLedgerEntry {
  id                  Int                @id @default(autoincrement())
  entryNo             String             @unique
  month               String
  transactionDate     DateTime
  sourceType          String             @default("manual")
  direction           String
  counterparty        String
  originalAmount      Float
  currency            String             @default("CNY")
  exchangeRate        Float              @default(1)
  localAmount         Float
  businessType        String?
  orderNo             String?
  customerOrderNo     String?
  salespersonName     String?
  customerServiceName String?
  supplierName        String?
  note                String?
  status              String             @default("draft")
  createdBy           String
  confirmedBy         String?
  confirmedAt         DateTime?
  voidedBy            String?
  voidedAt            DateTime?
  voidReason          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  attachments         LedgerAttachment[]
  bankTransaction     BankTransaction?

  @@index([month, transactionDate])
  @@index([month, direction, status])
  @@index([orderNo])
  @@index([customerOrderNo])
}

model LedgerAttachment {
  id          Int               @id @default(autoincrement())
  entryId     Int
  entry       ManualLedgerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  fileName    String
  contentType String
  fileSize    Int
  sha256      String
  fileData    Bytes
  createdAt   DateTime          @default(now())

  @@unique([entryId, sha256])
  @@index([entryId])
}

model ActionLog {
  id             Int      @id @default(autoincrement())
  month          String?
  entityType     String
  entityId       String
  action         String
  operator       String   @default("主管")
  operatorUserId Int?
  operatorRole   String?
  ipAddress      String?
  userAgent      String?
  requestId      String?
  beforeJson     String?
  afterJson      String?
  payloadJson    String?
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
  @@index([month, action])
  @@index([operatorUserId, createdAt])
}
