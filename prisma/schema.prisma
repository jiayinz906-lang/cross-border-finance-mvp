generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  displayName  String
  role         String
  passwordHash String
  passwordSalt String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FinanceOrder {
  id                          Int                     @id @default(autoincrement())
  importBatchId               Int?
  importBatch                 ImportBatch?            @relation(fields: [importBatchId], references: [id])
  orderNo                     String                  @unique
  customerOrderNo             String?
  orderDate                   DateTime
  month                       String
  customerName                String
  customerType                String
  salespersonName             String
  customerServiceName         String?
  businessType                String
  supplierName                String?
  currency                    String
  exchangeRate                Float?
  exchangeRateSource          String?
  exchangeRateStatus          String
  receivableFreight           Float                   @default(0)
  receivableClearance         Float                   @default(0)
  receivableDelivery          Float                   @default(0)
  receivableCompensation      Float                   @default(0)
  otherReceivable             Float                   @default(0)
  payableFreight              Float                   @default(0)
  payableClearance            Float                   @default(0)
  payableDelivery             Float                   @default(0)
  payableCompensation         Float                   @default(0)
  otherCost                   Float                   @default(0)
  adjustedReceivable          Float                   @default(0)
  adjustedPayable             Float                   @default(0)
  adjustedGrossProfit         Float                   @default(0)
  adjustedGrossProfitRate     Float?
  receivedAmount              Float                   @default(0)
  paidAmount                  Float                   @default(0)
  orderStatus                 String
  receivableStatus            String
  payableStatus               String
  isServiceBusiness           Boolean                 @default(false)
  isCompanyCustomerAdjusted   Boolean                 @default(false)
  needSupervisorConfirm       Boolean                 @default(false)
  calculationNote             String?
  remark                      String?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  commissionRecords           CommissionRecord[]
  riskRecords                 RiskRecord[]
  costAdjustments             CostAdjustment[]
  serviceBusinessRecords      ServiceBusinessRecord[]
  settlementRecords           SettlementRecord[]
}

model SettlementRecord {
  id              Int          @id @default(autoincrement())
  financeOrderId  Int
  financeOrder    FinanceOrder @relation(fields: [financeOrderId], references: [id])
  month           String
  direction       String
  amount          Float
  settledAt       DateTime
  counterparty    String?
  status          String       @default("active")
  operator        String       @default("finance")
  note            String?
  voidedBy        String?
  voidedAt        DateTime?
  voidReason      String?
  createdAt       DateTime     @default(now())

  @@index([month, direction])
  @@index([financeOrderId, direction])
}

model RawLedgerLine {
  id              Int         @id @default(autoincrement())
  importBatchId   Int
  importBatch     ImportBatch @relation(fields: [importBatchId], references: [id])
  month           String
  orderNo         String?
  customerOrderNo String?
  rowIndex        Int
  sheetName       String
  sourceFileName  String
  rowHash         String
  rawJson         String
  canonicalJson   String?
  parseStatus     String      @default("parsed")
  parseMessage    String?
  createdAt       DateTime    @default(now())

  @@index([month, orderNo])
  @@index([importBatchId, rowIndex])
  @@unique([importBatchId, rowIndex])
}

model ImportBatch {
  id                      Int            @id @default(autoincrement())
  batchNo                 String         @unique
  month                   String
  fileName                String
  sheetName               String
  importMode              String         @default("replace_month")
  status                  String         @default("active")
  importedRows            Int            @default(0)
  importedOrders          Int            @default(0)
  logisticsOrders         Int            @default(0)
  serviceOrders           Int            @default(0)
  totalReceivable         Float          @default(0)
  totalPayable            Float          @default(0)
  totalGrossProfit        Float          @default(0)
  riskOrderCount          Int            @default(0)
  abnormalHighProfitCount Int            @default(0)
  templateAuditJson       String?
  previewJson             String?
  createdBy               String         @default("system")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  revertedAt              DateTime?
  financeOrders           FinanceOrder[]
  rawLedgerLines          RawLedgerLine[]

  @@index([month, status])
}

model FinanceSummary {
  id                              Int      @id @default(autoincrement())
  month                           String   @unique
  totalReceivable                 Float    @default(0)
  totalPayable                    Float    @default(0)
  totalReceived                   Float    @default(0)
  totalPaid                       Float    @default(0)
  totalGrossProfit                Float    @default(0)
  grossProfitRate                 Float?
  totalCommission                 Float    @default(0)
  riskOrderCount                  Int      @default(0)
  abnormalHighProfitOrderCount    Int      @default(0)
  pendingSupervisorConfirmCount   Int      @default(0)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

model MonthClose {
  id              Int       @id @default(autoincrement())
  month           String    @unique
  status          String    @default("open")
  lockedBy        String?
  lockedAt        DateTime?
  unlockedBy      String?
  unlockedAt      DateTime?
  closeNote       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ExcelImportTemplate {
  id              Int      @id @default(autoincrement())
  templateKey     String   @unique
  fileName        String
  sheetName       String
  headerRowIndex  Int      @default(1)
  headersJson     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ParameterRule {
  id          Int      @id @default(autoincrement())
  ruleKey     String   @unique
  ruleGroup   String
  label       String
  valueJson   String
  description String?
  isActive    Boolean  @default(true)
  updatedBy   String   @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ruleGroup, isActive])
}

model CommissionRecord {
  id                      Int          @id @default(autoincrement())
  financeOrderId          Int
  financeOrder            FinanceOrder @relation(fields: [financeOrderId], references: [id])
  salespersonName         String
  customerType            String
  businessType            String
  grossProfit             Float
  commissionRate          Float
  commissionAmount        Float
  manualCommissionAmount  Float?
  adjustReason            String?
  needSupervisorConfirm   Boolean      @default(false)
  confirmStatus           String       @default("pending")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

model RiskRecord {
  id              Int          @id @default(autoincrement())
  financeOrderId  Int
  financeOrder    FinanceOrder @relation(fields: [financeOrderId], references: [id])
  riskLevel       String
  riskType        String
  riskReasons     String
  suggestion      String
  status          String       @default("open")
  reviewNote      String?
  reviewConclusion String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model CostAdjustment {
  id                      Int          @id @default(autoincrement())
  financeOrderId          Int
  financeOrder            FinanceOrder @relation(fields: [financeOrderId], references: [id])
  fieldName               String
  oldValue                Float?
  newValue                Float?
  adjustmentLogic         String
  reason                  String
  operatorName            String
  needSupervisorConfirm   Boolean      @default(false)
  createdAt               DateTime     @default(now())
}

model ServiceBusinessRecord {
  id                          Int          @id @default(autoincrement())
  financeOrderId              Int
  financeOrder                FinanceOrder @relation(fields: [financeOrderId], references: [id])
  serviceType                 String
  originalPrice               Float
  suggestedPrice              Float?
  suggestedCommissionMin      Float?
  suggestedCommissionMax      Float?
  costAmount                  Float?
  grossProfit                 Float?
  supervisorFinalPrice        Float?
  supervisorFinalCommission   Float?
  confirmStatus               String       @default("pending")
  remark                      String?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
}

model ConfirmationDocument {
  id                  Int       @id @default(autoincrement())
  month               String
  documentType        String
  ownerName           String
  version             Int       @default(1)
  businessType        String?
  orderCount          Int       @default(0)
  grossProfit         Float     @default(0)
  commissionAmount    Float     @default(0)
  payloadJson         String?
  documentStatus      String    @default("generated")
  sendStatus          String    @default("unsent")
  signatureStatus     String    @default("pending")
  supervisorStatus    String    @default("pending")
  signatureToken      String?   @unique
  signatureUrl        String?
  signatureTokenExpiresAt DateTime?
  signerIp            String?
  signerUserAgent     String?
  signerRole          String?
  signatureEvidenceJson String?
  adjustReason        String?
  voidReason          String?
  signedAt            DateTime?
  confirmedAt         DateTime?
  voidedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([month, documentType])
  @@index([month, documentType, ownerName])
  @@unique([month, documentType, ownerName, version])
}

model ExportJob {
  id          Int      @id @default(autoincrement())
  month       String
  exportType  String
  fileFormat  String
  status      String   @default("ready")
  fileName    String
  payloadJson String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([month, exportType])
}

model ActionLog {
  id          Int      @id @default(autoincrement())
  month       String?
  entityType  String
  entityId    String
  action      String
  operator    String   @default("主管")
  payloadJson String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}
