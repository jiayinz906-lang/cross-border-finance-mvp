# Copy to .env.production on the server and replace every CHANGE_ME value.
# Do not commit .env.production.
POSTGRES_DB=xjd_finance
POSTGRES_USER=xjd_finance_user
POSTGRES_PASSWORD=CHANGE_ME_PRODUCTION_DATABASE_PASSWORD
DATABASE_URL=postgresql://xjd_finance_user:CHANGE_ME_PRODUCTION_DATABASE_PASSWORD@postgres:5432/xjd_finance?schema=public

PORT=4000
NODE_ENV=production
AUTH_TOKEN_SECRET=CHANGE_ME_PRODUCTION_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
AUTH_REQUIRE_TOKEN=true
ALLOW_HEADER_ROLE=false
CORS_ALLOWED_ORIGINS=http://localhost
PUBLIC_APP_URL=http://localhost/
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_PRODUCTION_ADMIN_PASSWORD
ENABLE_LEGACY_DEFAULT_USERS=false

# Optional verification account. Use a dedicated read-only/administrator test account after first login.
FINANCE_TEST_USERNAME=
FINANCE_TEST_PASSWORD=

UPLOAD_MAX_MB=25
IMAGE_UPLOAD_MAX_MB=10
HEALTH_DB_TIMEOUT_MS=5000
SLOW_REQUEST_THRESHOLD_MS=2000
HTTP_REQUEST_TIMEOUT_MS=120000
DB_BACKUP_OUTPUT_DIR=outputs/db-backups

WECOM_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
DINGTALK_WEBHOOK_SECRET=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ROBOT_CODE=
