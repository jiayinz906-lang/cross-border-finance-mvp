# Local host development (without Docker). Never commit real passwords or secrets.
DATABASE_URL="postgresql://xjd_finance_user:replace-with-local-password@localhost:5432/xjd_finance?schema=public"
PORT=4000
NODE_ENV=development

# Frontend build-time configuration.
VITE_API_BASE_URL="http://localhost:4000/api"
VITE_PUBLIC_APP_URL="http://localhost:5173/"

# Authentication and browser access.
AUTH_TOKEN_SECRET="replace-with-a-long-random-secret"
AUTH_REQUIRE_TOKEN=true
ALLOW_HEADER_ROLE=false
CORS_ALLOWED_ORIGINS="http://localhost:5173"
PUBLIC_APP_URL="http://localhost:5173/"

# Used only when AppUser is empty. The initial password must be changed after login.
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_DISPLAY_NAME="系统管理员"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-at-least-10-characters"
ENABLE_LEGACY_DEFAULT_USERS=false

# Optional non-production verification account. Leave blank unless running authenticated smoke tests.
FINANCE_TEST_USERNAME=""
FINANCE_TEST_PASSWORD=""

# Upload and operational limits.
UPLOAD_MAX_MB=25
IMAGE_UPLOAD_MAX_MB=10
HEALTH_DB_TIMEOUT_MS=5000
SLOW_REQUEST_THRESHOLD_MS=2000
HTTP_REQUEST_TIMEOUT_MS=120000

# Command-line PostgreSQL backup output. Backups are written outside the database volume.
DB_BACKUP_OUTPUT_DIR="outputs/db-backups"

# Optional notification channels. Keep credentials server-side only.
WECOM_WEBHOOK_URL=""
DINGTALK_WEBHOOK_URL=""
DINGTALK_WEBHOOK_SECRET=""
DINGTALK_APP_KEY=""
DINGTALK_APP_SECRET=""
DINGTALK_ROBOT_CODE=""
