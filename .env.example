# Optional: Enterprise WeChat robot webhook. When configured, generated signature links are delivered to this bot.
WECOM_WEBHOOK_URL=""
# Optional: DingTalk group robot webhook. DingTalk is selected before WeCom when both are configured.
DINGTALK_WEBHOOK_URL=""
# Required only when the DingTalk robot enables signing.
DINGTALK_WEBHOOK_SECRET=""
# DingTalk internal app direct-message channel. App credentials remain server-side only.
DINGTALK_APP_KEY=""
DINGTALK_APP_SECRET=""
# Optional. Defaults to DINGTALK_APP_KEY when omitted.
DINGTALK_ROBOT_CODE=""
