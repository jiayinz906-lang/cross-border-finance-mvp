{
  "name": "cross-border-finance-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight cross-border logistics finance management MVP.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "pnpm --filter cross-border-finance-server dev",
    "dev:client": "pnpm --filter cross-border-finance-client dev",
    "build": "pnpm build:server && pnpm build:client",
    "build:server": "pnpm --filter cross-border-finance-server build",
    "build:client": "pnpm --filter cross-border-finance-client build",
    "build:render": "pnpm prisma:deploy && pnpm --filter cross-border-finance-client build && pnpm --filter cross-border-finance-server build",
    "start:render": "cd server && node dist/index.js",
    "verify:all": "tsx scripts/verify-all.ts",
    "verify:import": "tsx scripts/verify-import.ts",
    "verify:ui": "tsx scripts/verify-ui-smoke.ts",
    "verify:roles": "tsx scripts/verify-role-http.ts",
    "verify:role-matrix": "tsx scripts/verify-role-matrix.ts",
    "verify:manual-ledger": "tsx scripts/verify-manual-ledger.ts",
    "verify:finance-operations": "tsx scripts/verify-finance-operations.ts",
    "verify:data-foundation": "tsx scripts/verify-data-foundation.ts",
    "verify:operations": "tsx scripts/verify-operations.ts",
    "audit:money-precision": "tsx scripts/audit-money-precision.ts",
    "doctor": "tsx scripts/doctor.ts",
    "doctor:docker": "tsx scripts/doctor.ts --env-file=.env.production --client-url=http://localhost/ --api-url=http://localhost/api",
    "backup:system": "tsx scripts/export-system-backup.ts",
    "backup:db": "tsx scripts/backup-postgres-db.ts --env-file=.env.production --compose-file=docker-compose.prod.yml",
    "backup:db:dev": "tsx scripts/backup-postgres-db.ts --env-file=.env.docker --compose-file=docker-compose.dev.yml",
    "backup:legacy-sqlite": "tsx scripts/backup-sqlite-db.ts",
    "verify:db-backup": "tsx scripts/verify-postgres-backup.ts --env-file=.env.production --compose-file=docker-compose.prod.yml",
    "verify:ui:docker": "tsx scripts/verify-ui-smoke.ts --env-file=.env.production --client-url=http://localhost/ --api-url=http://localhost/api",
    "reset:business-data": "tsx scripts/reset-business-data.ts",
    "prisma:generate": "prisma generate",
    "prisma:prepare-import-archive": "prisma db execute --file prisma/import-archive-schema.sql --schema prisma/schema.prisma",
    "prisma:deploy": "prisma generate && tsx scripts/deploy-prisma-schema.ts",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
