{
  "name": "cross-border-finance-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight cross-border logistics finance management MVP.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build:server && npm run build:client",
    "build:server": "npm run build -w server",
    "build:client": "npm run build -w client",
    "build:render": "pnpm prisma:deploy && pnpm --filter cross-border-finance-client build && pnpm --filter cross-border-finance-server build && pnpm prisma db seed",
    "start:render": "cd server && node dist/index.js",
    "verify:import": "tsx scripts/verify-import.ts",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma generate && prisma db push",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
