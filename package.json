{
  "name": "cross-border-finance-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight cross-border logistics finance management MVP.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "pnpm --filter cross-border-finance-server dev",
    "dev:client": "pnpm --filter cross-border-finance-client dev",
    "build": "pnpm build:server && pnpm build:client",
    "build:server": "pnpm --filter cross-border-finance-server build",
    "build:client": "pnpm --filter cross-border-finance-client build",
    "build:render": "pnpm prisma:deploy && pnpm --filter cross-border-finance-client build && pnpm --filter cross-border-finance-server build",
    "start:render": "cd server && node dist/index.js",
    "verify:all": "tsx scripts/verify-all.ts",
    "verify:import": "tsx scripts/verify-import.ts",
    "verify:ui": "tsx scripts/verify-ui-smoke.ts",
    "doctor": "tsx scripts/doctor.ts",
    "backup:system": "tsx scripts/export-system-backup.ts",
    "backup:db": "tsx scripts/backup-sqlite-db.ts",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma generate && prisma db push",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
